# terraform.tfvars.example
# このファイルをコピーして terraform.tfvars を作成し、実際の値を入力してください。
# terraform.tfvars は .gitignore 対象です。コミットしないでください。

# 00_Baseline の apply 後に以下で取得できます。
#   cd ../../00_Baseline
#   terraform output sso_instance_arn
#   terraform output learner_admin_permission_set_arn
#   terraform output learner_account_id

sso_instance_arn                 = "arn:aws:sso:::instance/ssoins-xxxxxxxxxxxxxxxxx"
learner_admin_permission_set_arn = "arn:aws:sso:::permissionSet/ssoins-xxxxxxxxxxxxxxxxx/ps-xxxxxxxxxxxxxxxxx"
learner_account_id               = "123456789012"
