# =============================================================================
# versions.tf
# Terraform / OpenTofu バージョン制約とプロバイダバージョンのピン留め。
# =============================================================================

terraform {
  # Terraform 1.5+ および OpenTofu 1.5+ の両方で動作するよう下限を 1.5 に設定。
  # 本ハンズオンは Terraform を正とするが、OpenTofu でも実行できる。
  required_version = ">= 1.5.0"

  required_providers {
    aws = {
      source = "hashicorp/aws"
      # ~> 6.0 は 6.x 系の最新パッチを自動で取得しつつ、7.0 への意図しないメジャーアップを防ぐ。
      version = "~> 6.0"
    }
  }
}
