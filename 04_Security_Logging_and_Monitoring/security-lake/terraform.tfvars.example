# terraform.tfvars.example
# このファイルをコピーして terraform.tfvars を作成する。
# terraform.tfvars には実際の値が入るため git にコミットしないこと。
#
#   cp terraform.tfvars.example terraform.tfvars
#
# 【apply 前の推奨手順】
# config-securityhub モジュールを先に apply しておくと、Security Hub Findings
# ソース（SH_FINDINGS）が apply 直後からデータを流し始めるため体験価値が高い。
#
# 【初回 apply の注意】
# Security Lake は初回有効化時に AmazonSecurityLakeMetaStoreManager サービスリンクロールを
# 自動作成する。ロール作成に時間がかかる場合、apply 中に以下のエラーが出ることがある：
#   Error: AccessDeniedException: ...AWSServiceRoleForSecurityLake...
# この場合は数分待ってから再度 terraform apply を実行する。

project_name = "scs-handson"
region       = "ap-northeast-1"
aws_profile  = "terraform-sso"
