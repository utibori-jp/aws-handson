# terraform.tfvars.example
# このファイルをコピーして terraform.tfvars を作成し、実際の値を入力してください。
# terraform.tfvars は .gitignore 対象です。コミットしないでください。

# Learner アカウントの ID（00_Baseline の output から取得）。
# cd ../../00_Baseline && terraform output learner_account_id
learner_account_id = "123456789012"

# Peer アカウントの ID（Security Hub 委任管理者として使用）。
# cd ../../00_Baseline && terraform output peer_account_id
peer_account_id = "234567890123"
